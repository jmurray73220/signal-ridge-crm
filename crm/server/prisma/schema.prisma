// This is your Prisma schema file
// SQLite does not support native enums; enum values are stored as strings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               String?         // UserRole: Admin | Editor | Viewer | null (workflow-only user)
  workflowRole       String? // WorkflowRole: WorkflowAdmin | WorkflowEditor | WorkflowViewer
  workflowClientId   String?
  workflowClient     WorkflowClient? @relation("WorkflowClientUsers", fields: [workflowClientId], references: [id])
  isActive           Boolean         @default(true)
  mustChangePassword Boolean         @default(false)
  lastLogin          DateTime?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Audit trail relations
  contactsCreated     Contact[]     @relation("ContactCreatedBy")
  contactsUpdated     Contact[]     @relation("ContactUpdatedBy")
  entitiesCreated     Entity[]      @relation("EntityCreatedBy")
  entitiesUpdated     Entity[]      @relation("EntityUpdatedBy")
  initiativesCreated  Initiative[]  @relation("InitiativeCreatedBy")
  initiativesUpdated  Initiative[]  @relation("InitiativeUpdatedBy")
  interactionsCreated Interaction[] @relation("InteractionCreatedBy")
  interactionsUpdated Interaction[] @relation("InteractionUpdatedBy")
  tasksCreated        Task[]        @relation("TaskCreatedBy")
  tasksUpdated        Task[]        @relation("TaskUpdatedBy")
  remindersCreated    Reminder[]    @relation("ReminderCreatedBy")
  remindersUpdated    Reminder[]    @relation("ReminderUpdatedBy")

  // Workflow audit relations
  workflowActionItemsCreated WorkflowActionItem[] @relation("WorkflowActionItemCreatedBy")
  workflowActionItemsUpdated WorkflowActionItem[] @relation("WorkflowActionItemUpdatedBy")
  workflowSOWsCreated        WorkflowSOW[]        @relation("WorkflowSOWCreatedBy")
  workflowSOWVersionsCreated WorkflowSOWVersion[] @relation("WorkflowSOWVersionCreatedBy")
  workflowCommentsCreated    WorkflowComment[]    @relation("WorkflowCommentCreatedBy")
  workflowTracksCreated      WorkflowTrack[]      @relation("WorkflowTrackCreatedBy")
  workflowPhasesCreated      WorkflowPhase[]      @relation("WorkflowPhaseCreatedBy")
  workflowMilestonesCreated  WorkflowMilestone[]  @relation("WorkflowMilestoneCreatedBy")

  // Change log author
  changeLogEntries ChangeLog[] @relation("ChangeLogUser")

  // API keys that act as this user
  apiKeys ApiKey[] @relation("ApiKeyUser")
}

// ─── Bot / Machine API Keys ──────────────────────────────────────────────────
//
// Each row is a single API key that can be passed as
// `Authorization: Bearer <plaintext>`. We store only the SHA-256 hash of the
// plaintext; `keyPrefix` is the first 12 chars kept in the clear for display
// and humans identifying the key in the DB. Bots act as a real User row, so
// `userId` carries the audit trail. Revoke by setting `revokedAt`.

model ApiKey {
  id         String    @id @default(uuid())
  label      String
  keyHash    String    @unique
  keyPrefix  String
  userId     String
  user       User      @relation("ApiKeyUser", fields: [userId], references: [id])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
}

model Contact {
  id          String  @id @default(uuid())
  firstName   String
  lastName    String
  rank        String?
  title       String?
  email       String?
  officePhone String?
  cell        String?
  linkedIn    String?
  website     String?
  bio         String?
  tags        String  @default("[]") // JSON array stored as string in SQLite
  // Issue portfolios — only meaningful for committee staff (entity name
  // contains "committee"). Free-form list with a seed bank exposed via
  // /api/contacts/issue-portfolios; new portfolios just get added by name.
  issuePortfolios String @default("[]")
  entityId    String?
  entity      Entity? @relation(fields: [entityId], references: [id])

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Audit trail
  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("ContactCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("ContactUpdatedBy", fields: [updatedByUserId], references: [id])

  initiatives   InitiativeContact[]
  interactions  InteractionContact[]
  tasks         Task[]
  reminders     Reminder[]
  pendingEmails GmailPendingEmail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Entity {
  id          String  @id @default(uuid())
  name        String
  entityType  String // EntityType: CongressionalOffice | GovernmentOrganization | Company | NGO | Other
  website     String?
  description String?
  address     String?
  tags        String  @default("[]") // JSON array stored as string in SQLite

  // Congressional Office fields
  memberName   String?
  chamber      String? // Chamber: Senate | House
  state        String?
  district     String?
  committee    String? @default("[]") // JSON array
  party        String? // Party: Republican | Democrat | Independent
  subcommittee String? @default("[]") // JSON array

  // Government Organization fields
  parentAgency   String?
  subComponent   String?
  governmentType String? // GovernmentType: DoD | Intel | DHS | State | Other
  budgetLineItem String?

  // Company fields
  industry              String?
  contractVehicles      String? @default("[]") // JSON array
  capabilityDescription String?

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Audit trail
  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("EntityCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("EntityUpdatedBy", fields: [updatedByUserId], references: [id])

  contacts        Contact[]
  pendingEmails   GmailPendingEmail[]
  initiatives     Initiative[]        @relation("PrimaryEntity")
  initiativeLinks InitiativeEntity[]
  interactions    Interaction[]
  tasks           Task[]
  reminders       Reminder[]
  briefingDocsAsOffice BriefingDocument[] @relation("BriefingDocsOffice")
  briefingDocsAsClient BriefingDocument[] @relation("BriefingDocsClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Initiative {
  id              String    @id @default(uuid())
  title           String
  description     String?
  status          String    @default("Pipeline") // InitiativeStatus: Active | Pipeline | OnHold | Closed
  priority        String    @default("Medium") // InitiativePriority: High | Medium | Low
  startDate       DateTime?
  targetDate      DateTime?
  primaryEntityId String?
  primaryEntity   Entity?   @relation("PrimaryEntity", fields: [primaryEntityId], references: [id])

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Audit trail
  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("InitiativeCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("InitiativeUpdatedBy", fields: [updatedByUserId], references: [id])

  contacts     InitiativeContact[]
  entities     InitiativeEntity[]
  interactions Interaction[]
  tasks        Task[]
  reminders    Reminder[]
  briefingDocs BriefingDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InitiativeContact {
  initiativeId String
  contactId    String
  role         String?
  sortOrder    Int     @default(0)

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  contact    Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([initiativeId, contactId])
}

model InitiativeEntity {
  initiativeId     String
  entityId         String
  relationshipNote String?

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([initiativeId, entityId])
}

model Interaction {
  id             String      @id @default(uuid())
  type           String // InteractionType: Meeting | Call | Email | Hearing | Briefing | Event | Other
  date           DateTime
  subject        String
  notes          String?
  gmailThreadUrl String?
  entityId       String?
  entity         Entity?     @relation(fields: [entityId], references: [id])
  initiativeId   String?
  initiative     Initiative? @relation(fields: [initiativeId], references: [id])

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Audit trail
  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("InteractionCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("InteractionUpdatedBy", fields: [updatedByUserId], references: [id])

  contacts    InteractionContact[]
  reminders   Reminder[]
  attachments InteractionAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InteractionAttachment {
  id               String      @id @default(uuid())
  interactionId    String
  interaction      Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  filename         String
  mimeType         String
  fileData         String      // Base64-encoded original file (so it can be downloaded back)
  extractedText    String      // Extracted text for search / AI use; empty for non-text formats
  source           String?     // Free-form: "gemini" | "otter" | "manual" | "bubba" | etc.
  uploadedAt       DateTime    @default(now())
  uploadedByUserId String?

  @@index([interactionId])
}

model InteractionContact {
  interactionId String
  contactId     String

  interaction Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([interactionId, contactId])
}

model Task {
  id           String    @id @default(uuid())
  title        String
  dueDate      DateTime?
  completed    Boolean   @default(false)
  contactId    String?
  entityId     String?
  initiativeId String?

  contact    Contact?    @relation(fields: [contactId], references: [id])
  entity     Entity?     @relation(fields: [entityId], references: [id])
  initiative Initiative? @relation(fields: [initiativeId], references: [id])

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Audit trail
  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("TaskUpdatedBy", fields: [updatedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reminder {
  id          String    @id @default(uuid())
  title       String
  notes       String?
  remindAt    DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?

  contactId     String?
  entityId      String?
  initiativeId  String?
  interactionId String?

  contact     Contact?     @relation(fields: [contactId], references: [id])
  entity      Entity?      @relation(fields: [entityId], references: [id])
  initiative  Initiative?  @relation(fields: [initiativeId], references: [id])
  interaction Interaction? @relation(fields: [interactionId], references: [id])

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("ReminderUpdatedBy", fields: [updatedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Audit: Change Log ───────────────────────────────────────────────────────
//
// Polymorphic append-only log of every create/update/delete across the core
// CRM and workflow models. Admin-only visibility in the UI. `entityType` is
// a free string (e.g. "Contact", "Entity", "WorkflowTrack") so we can add new
// tracked types without another migration. `diff` stores a JSON object whose
// shape depends on `action`:
//   - create: { after: <full-record-snapshot> }
//   - update: { fields: { <name>: { before, after } } }
//   - delete: { snapshot: <full-record-at-delete-time> }
//   - restore / purge: {}

model ChangeLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  userId     String?
  user       User?    @relation("ChangeLogUser", fields: [userId], references: [id])
  action     String // create | update | delete | restore | purge
  diff       String   @default("{}") // JSON string
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── CRM Settings ────────────────────────────────────────────────────────────

model CrmSettings {
  id            String   @id @default("singleton")
  majorityParty String   @default("Republican") // Republican | Democrat
  logoData      String? // Base64-encoded logo image
  logoMimeType  String? // e.g., image/png
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Gmail Sync ───────────────────────────────────────────────────────────────

model GmailCredential {
  id           String    @id @default("singleton")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  accountEmail String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model GmailSyncSettings {
  id                  String    @id @default("singleton")
  enabled             Boolean   @default(false)
  syncIntervalMinutes Int       @default(60)
  lastSyncAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model GmailPendingEmail {
  id                String   @id @default(uuid())
  threadId          String   @unique
  subject           String
  from              String
  snippet           String?
  emailDate         DateTime
  status            String   @default("pending") // pending | approved | dismissed
  contactId         String?
  contact           Contact? @relation(fields: [contactId], references: [id])
  entityId          String?
  entity            Entity?  @relation(fields: [entityId], references: [id])
  matchedContactIds String   @default("[]") // JSON array of all matched contact IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Briefing Documents (uploaded reference briefings for AI generation) ────

model BriefingDocument {
  id              String   @id @default(uuid())
  // Office the meeting was held at (this is where the upload UI lives).
  officeId        String
  office          Entity   @relation("BriefingDocsOffice", fields: [officeId], references: [id], onDelete: Cascade)
  // The client the briefing was prepared for. Drives retrieval at generation time.
  clientId        String
  client          Entity   @relation("BriefingDocsClient", fields: [clientId], references: [id], onDelete: Cascade)
  // Optional initiative this briefing was associated with.
  initiativeId    String?
  initiative      Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)
  filename        String
  mimeType        String
  extractedText   String   // Full text extracted at upload time
  tags            String   @default("[]") // JSON array of free-text tags
  meetingDate     DateTime?
  uploadedAt      DateTime @default(now())
  uploadedByUserId String?

  @@index([clientId])
  @@index([officeId])
  @@index([initiativeId])
}

// ─── Budget Intelligence ─────────────────────────────────────────────────────

model BudgetDocument {
  id            String   @id @default(uuid())
  name          String?
  documentType  String // J-Book, NDAA, Appropriations Bill, etc.
  fiscalYear    String
  serviceBranch String // Army, Navy, Air Force, Space Force, Defense-Wide, Congress, etc.
  extractedText String // Full text of the document
  createdAt     DateTime @default(now())

  conversations BudgetConversation[]
}

model BudgetConversation {
  id               String         @id @default(uuid())
  budgetDocumentId String
  budgetDocument   BudgetDocument @relation(fields: [budgetDocumentId], references: [id], onDelete: Cascade)
  messages         String         @default("[]") // JSON array of messages
  createdAt        DateTime       @default(now())

  links BudgetLink[]
}

model BudgetLink {
  id                   String             @id @default(uuid())
  budgetConversationId String
  budgetConversation   BudgetConversation @relation(fields: [budgetConversationId], references: [id], onDelete: Cascade)
  entityType           String // CongressionalOffice | GovernmentOrganization | Company
  entityId             String
  note                 String?
  createdAt            DateTime           @default(now())
}

model ReportTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  fileData    String // Base64-encoded .docx file
  createdAt   DateTime @default(now())
}

// ─── Workflow ────────────────────────────────────────────────────────────────

model WorkflowClient {
  id        String   @id @default(uuid())
  name      String
  clientId  String? // Links to CRM Entity.id (soft reference; not FK to avoid coupling)
  // When true this is an internal Signal Ridge workspace (no CRM client),
  // not a customer engagement. UI groups these separately and the
  // AddClient flow lets internal entries be created without a CRM link.
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  tracks WorkflowTrack[]
  sows   WorkflowSOW[]
  users  User[]          @relation("WorkflowClientUsers")
}

model WorkflowTrack {
  id               String         @id @default(uuid())
  workflowClientId String
  workflowClient   WorkflowClient @relation(fields: [workflowClientId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  fundingVehicle   String?
  status           String         @default("Active") // Active | OnHold | Completed | Archived
  priority         String         @default("Medium") // High | Medium | Low — mirrors Initiative.priority
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Contract opportunity flag + opportunity fields. Drives whether the
  // track gets a SOW button, opportunity field section, and seeded
  // proposal-cycle phases. Most fields filled in by Claude when the user
  // supplies a URL or pasted page text.
  isContractOpportunity Boolean   @default(false)
  opportunityUrl        String?
  solicitationNumber    String?
  vehicleType           String?   // SBIR-PhI | SBIR-PhII | STTR | OTA | BAA | CSO | RFP | IDIQ-TO | Grant | Other
  issuingAgency         String?   // e.g. "USSOCOM SOF AT&L", "AFRL/RIGA"
  questionsDueDate      DateTime?
  proposalDueDate       DateTime?
  periodOfPerformance   String?
  fundingCeiling        String?
  fundingFloor          String?
  fundingAuthority      String?   // e.g. "10 U.S.C. 4022 and 4023"
  eligibility           String?
  submissionFormat      String?
  objective             String?
  focusAreas            String    @default("[]") // JSON: [{name, summary}]
  targetedFocusAreas    String    @default("[]") // JSON array of names the user picked as in-scope
  focusAreasConfirmedAt DateTime? // null = user hasn't yet picked. set = user confirmed; UI hides non-targeted areas.
  pointsOfContact       String    @default("[]") // JSON: [{name, role, email}]
  additionalSections    String    @default("[]") // JSON: [{heading, content}] — catch-all
  aiExtractionStatus    String?   // pending | ok | partial | blocked | failed
  aiExtractedAt         DateTime?

  // Mirror into CRM Initiative (soft link — not FK so the workflow tool stays
  // decoupled from CRM table changes). Tracks create a companion Initiative in
  // the CRM with primaryEntity = the workflow client's CRM Entity.
  initiativeId String?

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  // Creator (who entered this track). Nullable for rows created before tracking.
  createdByUserId String?
  createdBy       User?   @relation("WorkflowTrackCreatedBy", fields: [createdByUserId], references: [id])

  phases WorkflowPhase[]
  sow    WorkflowSOW?
}

model WorkflowPhase {
  id          String        @id @default(uuid())
  trackId     String
  track       WorkflowTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  title       String
  description String?
  budget      String?
  timeframe   String?
  status      String        @default("NotStarted") // NotStarted | InProgress | Completed | Blocked
  // When true, the user has explicitly set status; auto-derive from milestones is skipped.
  statusManuallySet Boolean @default(false)
  // Single free-form assignee — display name pulled from the client's
  // CRM contacts + active users (see listAssignees). Mirrors the existing
  // assignedTo on WorkflowActionItem.
  assignedTo  String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Creator (who entered this phase). Nullable for rows created before tracking.
  createdByUserId String?
  createdBy       User?     @relation("WorkflowPhaseCreatedBy", fields: [createdByUserId], references: [id])

  milestones  WorkflowMilestone[]
  attachments PhaseAttachment[]
  links       PhaseLink[]
}

model PhaseAttachment {
  id               String        @id @default(uuid())
  phaseId          String
  phase            WorkflowPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  filename         String
  mimeType         String
  fileData         String        // Base64-encoded original file
  uploadedAt       DateTime      @default(now())
  uploadedByUserId String?

  @@index([phaseId])
}

model PhaseLink {
  id        String        @id @default(uuid())
  phaseId   String
  phase     WorkflowPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  url       String
  label     String?       // optional display name; falls back to URL hostname
  createdAt DateTime      @default(now())
  createdByUserId String?

  @@index([phaseId])
}

model WorkflowMilestone {
  id          String        @id @default(uuid())
  phaseId     String
  phase       WorkflowPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      String        @default("NotStarted") // NotStarted | InProgress | Completed | Blocked
  // When true, the user has explicitly set status; auto-derive from action items is skipped.
  statusManuallySet Boolean @default(false)
  // Single free-form assignee — same pattern as WorkflowPhase / WorkflowActionItem.
  assignedTo  String?
  completedAt DateTime?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Creator (who entered this step). Nullable for rows created before tracking.
  createdByUserId String?
  createdBy       User?     @relation("WorkflowMilestoneCreatedBy", fields: [createdByUserId], references: [id])

  actionItems WorkflowActionItem[]
}

model WorkflowActionItem {
  id          String            @id @default(uuid())
  milestoneId String
  milestone   WorkflowMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  title       String
  description String?
  notes       String?
  status      String            @default("Todo") // Todo | InProgress | Done | Blocked
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  createdByUserId String?
  updatedByUserId String?
  createdBy       User?   @relation("WorkflowActionItemCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy       User?   @relation("WorkflowActionItemUpdatedBy", fields: [updatedByUserId], references: [id])

  comments WorkflowComment[]
}

model WorkflowSOW {
  id                   String         @id @default(uuid())
  workflowClientId     String
  workflowClient       WorkflowClient @relation(fields: [workflowClientId], references: [id], onDelete: Cascade)
  // One optional SOW per track (unique enforces at-most-one).
  trackId              String?        @unique
  track                WorkflowTrack? @relation(fields: [trackId], references: [id], onDelete: SetNull)
  title                String
  // Structured fields
  targetFundingVehicle String?
  targetAgency         String?
  periodOfPerformance  String?
  budget               String?
  differentiationLayer String? // Layer1 | Layer2 | Layer3 | Layer4 | CrossLayer
  trlStatement         String?
  scope                String         @default("") // Rich text / markdown narrative
  keyPersonnel         String         @default("")
  deliverables         String         @default("[]") // JSON array of strings
  draftingChecklist    String         @default("[]") // JSON array of {id,title,done}
  // Legacy free-form content kept for backfill; new UI uses `scope` instead.
  content              String         @default("")
  version              Int            @default(1)
  status               String         @default("Draft")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  // Soft delete
  deletedAt       DateTime?
  deletedByUserId String?

  createdByUserId String?
  createdBy       User?   @relation("WorkflowSOWCreatedBy", fields: [createdByUserId], references: [id])

  versions WorkflowSOWVersion[]
  comments WorkflowComment[]
}

model WorkflowSOWVersion {
  id           String      @id @default(uuid())
  sowId        String
  sow          WorkflowSOW @relation(fields: [sowId], references: [id], onDelete: Cascade)
  content      String
  snapshotJson String      @default("{}") // Full structured-field snapshot at this version
  version      Int
  createdAt    DateTime    @default(now())

  createdByUserId String?
  createdBy       User?   @relation("WorkflowSOWVersionCreatedBy", fields: [createdByUserId], references: [id])
}

// ─── Bookmarklet Capture ─────────────────────────────────────────────────────
// When a user clicks the workflow bookmarklet on a foreign tab (e.g. an eBuy
// solicitation behind their login), the bookmarklet form-POSTs the scraped
// page text here. We persist it briefly so the user's CRM tab can pick it up
// and turn it into a contract opportunity track.

// Canonical bank of issue portfolios. Surfaced in the contact-edit
// checklist for committee staff. The seed (Intel, CYBERCOM, SOCOM,
// Army RDT&E, Navy RDT&E) is inserted by the controller on first read
// if the table is empty, so adding/renaming/deleting from this table
// is the source of truth — Contact.issuePortfolios just holds names.
model IssuePortfolio {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model BookmarkCapture {
  id         String    @id @default(uuid())
  userId     String
  pageUrl    String
  pageText   String    // Scraped innerText from the foreign tab — capped at ~200KB
  capturedAt DateTime  @default(now())
  consumedAt DateTime? // Set when the SPA picks it up and creates a track

  @@index([userId, consumedAt])
}

model WorkflowComment {
  id           String              @id @default(uuid())
  actionItemId String?
  actionItem   WorkflowActionItem? @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  sowId        String?
  sow          WorkflowSOW?        @relation(fields: [sowId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime            @default(now())

  createdByUserId String?
  createdBy       User?   @relation("WorkflowCommentCreatedBy", fields: [createdByUserId], references: [id])
}
